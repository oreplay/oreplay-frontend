{
  "name": "@oreplay/ranking",
  "version": "0.0.1",
  "description": "O-Replay ranking module — routes subtree mounted by the host app at /ranking/*",
  "type": "module",
  "files": ["dist"],
  "main": "./dist/oreplay-ranking.js",
  "module": "./dist/oreplay-ranking.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/oreplay-ranking.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext ts,tsx --max-warnings 0",
    "format": "prettier . --write",
    "before-commit": "npm run format && npm run lint && npm run build && npm run test"
  },
  "peerDependencies": {
    "@emotion/react": "^11",
    "@emotion/styled": "^11",
    "@mui/icons-material": "^6",
    "@mui/material": "^6",
    "i18next": "^23",
    "react": "^18",
    "react-dom": "^18",
    "react-i18next": "^14",
    "react-query": "^3",
    "react-router-dom": "^7"
  },
  "devDependencies": {
    "@emotion/react": "^11.11.3",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^6.4.5",
    "@mui/material": "^6.4.5",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "i18next": "^23.10.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prettier": "3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.2.0",
    "react-i18next": "^14.0.5",
    "react-query": "^3.39.3",
    "react-router-dom": "^7.2.0",
    "tailwindcss": "^3.4.17",
    "typescript": "5.5",
    "vite": "^6.1.1",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
