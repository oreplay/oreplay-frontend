{
  "name": "@oreplay/ranking",
  "version": "0.0.1",
  "description": "O-Replay ranking module — routes subtree mounted by the host app at /ranking/*",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oreplay/oreplay-ranking.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/oreplay-ranking.js",
  "module": "./dist/oreplay-ranking.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/oreplay-ranking.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "dev:css": "tailwindcss -i src/styles/tailwind.css -o src/styles/compiled.css --watch",
    "build:css": "tailwindcss -i src/styles/tailwind.css -o src/styles/compiled.css --minify",
    "build": "npm run build:css && tsc && vite build",
    "orval-build": "rm -f src/domain/types/v1api/index.ts && npx orval --config ./orval.config.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext ts,tsx --max-warnings 0",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "before-commit": "npm run format && npm run lint && npm run build && npm run test",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "axios": "^1.7.9",
    "i18next": "^23",
    "react": "^18",
    "react-dom": "^18",
    "react-i18next": "^14",
    "react-query": "^3",
    "react-router-dom": "^7"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "axios": "^1.7.9",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-jsonc": "^2.16.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "i18next": "^23.10.0",
    "i18next-browser-languagedetector": "^7.2.0",
    "i18next-http-backend": "^2.5.0",
    "jsdom": "^25.0.1",
    "jsonc-eslint-parser": "^2.4.0",
    "orval": "^7.21.0",
    "postcss": "^8.4.49",
    "prettier": "3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.2.0",
    "react-i18next": "^14.0.5",
    "react-query": "^3.39.3",
    "react-router-dom": "^7.2.0",
    "tailwindcss": "^3.4.17",
    "typescript": "5.5",
    "vite": "^6.1.1",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.22.0"
  }
}
