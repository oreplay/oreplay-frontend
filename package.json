{
  "name": "oreplay-frontend",
  "private": true,
  "version": "0.4.28",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "format": "npx prettier . --write",
    "orval-build": "rm -f src/domain/types/v1api/index.ts && npx orval --config ./orval.config.ts",
    "format:check": "npx prettier . --check",
    "lint": "eslint . --ext ts,tsx,json --report-unused-disable-directives --max-warnings 0",
    "before-commit": "npm run format && npm run lint && npm run test && npm run build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22.22.0"
  },
  "dependencies": {
    "@emotion/react": "^11.11.3",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@mui/x-data-grid": "^9.10.0",
    "@mui/x-date-pickers": "^9.10.0",
    "@nivo/bar": "^0.99.0",
    "@nivo/core": "^0.99.0",
    "@nivo/line": "^0.99.0",
    "@nivo/pie": "^0.99.0",
    "@nivo/radar": "^0.99.0",
    "@nivo/scatterplot": "^0.99.0",
    "@sentry/react": "^9.38.0",
    "@sentry/vite-plugin": "^3.6.0",
    "@tanstack/react-form": "^1.27.7",
    "@toolpad/core": "^0.16.0",
    "@types/luxon": "^3.4.2",
    "axios": "^1.7.9",
    "framer-motion": "^12.23.24",
    "html2canvas": "^1.4.1",
    "i18n-iso-countries": "^7.14.0",
    "i18next": "^23.10.0",
    "i18next-browser-languagedetector": "^7.2.0",
    "i18next-http-backend": "^4.0.0",
    "luxon": "^3.4.4",
    "qr-code-styling": "^1.9.2",
    "react": "^18.3.1",
    "react-dom": "^18.2.0",
    "react-i18next": "^14.0.5",
    "react-query": "^3.39.3",
    "react-router-dom": "^7.2.0"
  },
  "overrides": {
    "@toolpad/core": {
      "@mui/icons-material": "^9.2.0",
      "@mui/material": "^9.2.0"
    }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.2",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-jsonc": "^2.16.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^25.0.1",
    "jsonc-eslint-parser": "^2.4.2",
    "orval": "^8.22.0",
    "postcss": "^8.5.16",
    "prettier": "3.4.2",
    "tailwindcss": "^3.4.19",
    "typescript": "5.5",
    "vite": "^6.1.1",
    "vitest": "^3.2.4"
  }
